# reports service — example environment file.
#
# Copy to `stack.env` (gitignored) and fill in real values. Both docker-compose.yml
# (prod) and docker-compose.staging.yml load it via `env_file: stack.env`.
# All variables have defaults in code (internal/config/config.go) EXCEPT SMTP,
# which is required for report generation to succeed (see below).

# --- HTTP server ---
SERVER_PORT=8080

# --- Postgres (compose interpolation) ---
POSTGRES_USER=reports
POSTGRES_PASSWORD=change-me
POSTGRES_DB=reports_db
POSTGRES_CONTAINER_NAME=reports-postgres
POSTGRES_PORT=5432

# --- reports service (compose interpolation) ---
SERVICE_CONTAINER_NAME=reports
SERVICE_PORT=3010

# --- database (app config) ---
DB_HOST=reports-postgres
DB_PORT=5432
DB_USER=reports
DB_PASSWORD=change-me
DB_NAME=reports_db
DB_SSLMODE=disable

# --- logging / scheduling ---
LOG_LEVEL=info
REPORTING_TIMEZONE=America/Sao_Paulo
SCHEDULER_ENABLED=true

# --- upstream services (use container names in prod) ---
TRANSACTIONS_BASE_URL=http://transaction-service-v2:1235/api/v2
EVENTS_BASE_URL=http://events:3000
AI_INTERNAL_BASE_URL=http://ai-internal:3005
REPORTS_CALLBACK_BASE_URL=http://reports:8080

# --- report rendering ---
REPORT_LANGUAGE=en
REPORT_CURRENCY=BRL

# --- SMTP (REQUIRED for email delivery) ---
# Email is mandatory for a generation to succeed. SMTP_HOST, SMTP_PORT and
# SMTP_FROM must all be set or every generation fails with
# "email not sent: SMTP not configured". SMTP_USERNAME/SMTP_PASSWORD are
# optional (leave empty for an auth-less relay such as a local Mailpit).
# Gmail app-password example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
